1fa\u3002\u795e\u7ecf\u7f51\u7edc\u672c\u8d28\u5176\u5b9e\u5c31\u662f\u4e00\u4e2a\u51fd\u6570\u3002</p>"},{"location":"ai/deep_learning/neural_network/function.html#_2","title":"\u6700\u7b80\u5355\u7684\u51fd\u6570","text":"<p>\u6700\u7b80\u5355\u7684\u51fd\u6570\uff0c\u5c31\u662f\u8fd9\u79cd\u7ebf\u6027\u51fd\u6570\uff0c\u4e2d\u5b66\u5b66\u8fc7a\u662f\u659c\u7387\uff0cb\u662f\u504f\u79fb\u91cf\u3002\u5c31\u8fd9\u73a9\u610f\uff0c\u8fd9\u5176\u5b9e\u5c31\u662f\u6700\u7b80\u5355\u7684\u795e\u7ecf\u7f51\u7edc\u4e86\uff0c\u8f93\u5165\u4e00\u7ef4\uff0c\u8f93\u51fa\u4e00\u7ef4\u3002</p> <pre><code>y = ax + b\n</code></pre> <p>\u5176\u5b9e\u901a\u8fc7\u8fd9\u4e2a\u6700\u7b80\u5355\u7684\u51fd\u6570\u5c31\u53ef\u4ee5\u7406\u89e3\u5f88\u591a\u4e00\u4e9b\u6982\u5ff5\u4e86\uff0c\u6bd4\u5982\u8bad\u7ec3\uff0c\u6bd4\u5982\u63a8\u7406\uff0c\u524d\u5411\u4f20\u64ad\uff0c\u53cd\u5411\u4f20\u64ad\uff0closs\u7b49\u7b49\u3002\u6709\u4e9b\u590d\u6742\u7684\u4e1c\u897f\u5176\u5b9e\u901a\u8fc7\u6700\u7b80\u5355\u7684\u6a21\u578b\u53bb\u770b\u672c\u8d28\uff0c\u5176\u5b9e\u66f4\u597d\u7406\u89e3\u3002</p> <p>\u5f53\u7136\u8fd9\u4e9b\u901a\u8fc7\u8fd9\u4e2a\u6a21\u578b\u6765\u770b\u8fd9\u4e9b\u6982\u5ff5\u76f8\u5bf9\u90fd\u6bd4\u8f83\u7b80\u5355\uff0c\u5c31\u4e0d\u6269\u5c55\u4e86~</p>"},{"location":"ai/deep_learning/neural_network/function.html#_3","title":"\u7ebf\u6027\u56de\u5f52","text":"<p>\u8fd9\u4e2a\u6982\u5ff5\u542c\u5230\u5f88\u591a\uff0c\u600e\u4e48\u53bb\u7406\u89e3\u7ebf\u6027\u56de\u5f52\u8fd9\u4e2a\u6982\u5ff5\u4e86\uff0c\u5176\u5b9e\u548c\u8bad\u7ec3\u4e5f\u633a\u7c7b\u4f3c\u7684\uff0c\u5c31\u662f\u6211\u4eec\u6709\u5f88\u591a\u7684\u6570\u636e\u53bb\u62df\u5408\u4e00\u6761\u76f4\u7ebf\u89c4\u5f8b\uff0c\u8bad\u7ec3\u63a8\u51fa\u90a3\u4e48\u4e00\u4e2a\u51fd\u6570\u7684\u8fc7\u7a0b\uff0c\u6211\u7406\u89e3\u5c31\u53eb\u7ebf\u6027\u56de\u5f52\u3002</p> <p>\u6709\u70b9\u62bd\u8c61\uff0c\u53cd\u6b63\u5927\u6982\u5c31\u662f\u8fd9\u4e48\u4e2a\u8fc7\u7a0b~</p>"},{"location":"ai/deep_learning/neural_network/linear.html","title":"linear","text":"<p>\ud83d\udea7 \u6b63\u5728\u66f4\u65b0\u4e2d...</p>"},{"location":"ai/deep_learning/neural_network/linear.html#_1","title":"\ud83d\udccc \u8ba1\u5212\u5185\u5bb9","text":"<ul> <li>\uff08\u5f85\u8865\u5145\uff09</li> </ul>"},{"location":"ai/deep_learning/neural_network/loss.html","title":"loss","text":"<p>\ud83d\udea7 \u6b63\u5728\u66f4\u65b0\u4e2d...</p>"},{"location":"ai/deep_learning/neural_network/loss.html#_1","title":"\ud83d\udccc \u8ba1\u5212\u5185\u5bb9","text":"<ul> <li>\uff08\u5f85\u8865\u5145\uff09</li> </ul>"},{"location":"ai/frameworks/index.html","title":"frameworks","text":"<p>\ud83d\udea7 \u6b63\u5728\u66f4\u65b0\u4e2d...</p>"},{"location":"ai/frameworks/index.html#_1","title":"\ud83d\udccc \u8ba1\u5212\u5185\u5bb9","text":"<ul> <li>\uff08\u5f85\u8865\u5145\uff09</li> </ul>"},{"location":"ai/frameworks/datasets.html","title":"datasets","text":"<p>\ud83d\udea7 \u6b63\u5728\u66f4\u65b0\u4e2d...</p>"},{"location":"ai/frameworks/datasets.html#_1","title":"\ud83d\udccc \u8ba1\u5212\u5185\u5bb9","text":"<ul> <li>\uff08\u5f85\u8865\u5145\uff09</li> </ul>"},{"location":"ai/frameworks/huggingface.html","title":"huggingface","text":"<p>\ud83d\udea7 \u6b63\u5728\u66f4\u65b0\u4e2d...</p>"},{"location":"ai/frameworks/huggingface.html#_1","title":"\ud83d\udccc \u8ba1\u5212\u5185\u5bb9","text":"<ul> <li>\uff08\u5f85\u8865\u5145\uff09</li> </ul>"},{"location":"ai/frameworks/numpy.html","title":"numpy","text":"<p>\ud83d\udea7 \u6b63\u5728\u66f4\u65b0\u4e2d...</p>"},{"location":"ai/frameworks/numpy.html#_1","title":"\ud83d\udccc \u8ba1\u5212\u5185\u5bb9","text":"<ul> <li>\uff08\u5f85\u8865\u5145\uff09</li> </ul>"},{"location":"ai/frameworks/pytorch.html","title":"pytorch","text":"<p>\ud83d\udea7 \u6b63\u5728\u66f4\u65b0\u4e2d...</p>"},{"location":"ai/frameworks/pytorch.html#_1","title":"\ud83d\udccc \u8ba1\u5212\u5185\u5bb9","text":"<ul> <li>\uff08\u5f85\u8865\u5145\uff09</li> </ul>"},{"location":"ai/industry/index.html","title":"industry","text":"<p>\ud83d\udea7 \u6b63\u5728\u66f4\u65b0\u4e2d...</p>"},{"location":"ai/industry/index.html#_1","title":"\ud83d\udccc \u8ba1\u5212\u5185\u5bb9","text":"<ul> <li>\uff08\u5f85\u8865\u5145\uff09</li> </ul>"},{"location":"ai/math/index.html","title":"math","text":"<p>\ud83d\udea7 \u6b63\u5728\u66f4\u65b0\u4e2d...</p>"},{"location":"ai/math/index.html#_1","title":"\ud83d\udccc \u8ba1\u5212\u5185\u5bb9","text":"<ul> <li>\uff08\u5f85\u8865\u5145\uff09</li> </ul>"},{"location":"ai/math/information_theory.html","title":"information_theory","text":"<p>\ud83d\udea7 \u6b63\u5728\u66f4\u65b0\u4e2d...</p>"},{"location":"ai/math/information_theory.html#_1","title":"\ud83d\udccc \u8ba1\u5212\u5185\u5bb9","text":"<ul> <li>\uff08\u5f85\u8865\u5145\uff09</li> </ul>"},{"location":"ai/math/probability_statistics.html","title":"probability_statistics","text":"<p>\ud83d\udea7 \u6b63\u5728\u66f4\u65b0\u4e2d...</p>"},{"location":"ai/math/probability_statistics.html#_1","title":"\ud83d\udccc \u8ba1\u5212\u5185\u5bb9","text":"<ul> <li>\uff08\u5f85\u8865\u5145\uff09</li> </ul>"},{"location":"ai/math/calculus/index.html","title":"calculus","text":"<p>\ud83d\udea7 \u6b63\u5728\u66f4\u65b0\u4e2d...</p>"},{"location":"ai/math/calculus/index.html#_1","title":"\ud83d\udccc \u8ba1\u5212\u5185\u5bb9","text":"<ul> <li>\uff08\u5f85\u8865\u5145\uff09</li> </ul>"},{"location":"ai/math/calculus/chain_rule.html","title":"chain_rule","text":"<p>\ud83d\udea7 \u6b63\u5728\u66f4\u65b0\u4e2d...</p>"},{"location":"ai/math/calculus/chain_rule.html#_1","title":"\ud83d\udccc \u8ba1\u5212\u5185\u5bb9","text":"<ul> <li>\uff08\u5f85\u8865\u5145\uff09</li> </ul>"},{"location":"ai/math/calculus/derivative.html","title":"derivative","text":"<p>\ud83d\udea7 \u6b63\u5728\u66f4\u65b0\u4e2d...</p>"},{"location":"ai/math/calculus/derivative.html#_1","title":"\ud83d\udccc \u8ba1\u5212\u5185\u5bb9","text":"<ul> <li>\uff08\u5f85\u8865\u5145\uff09</li> </ul>"},{"location":"ai/math/linear_algebra/index.html","title":"\u603b\u89c8","text":"<p>\u7ebf\u6027\u4ee3\u6570\u5728\u8ba1\u7b97\u673a\u9886\u57df\u5e94\u7528\u662f\u5f88\u591a\u7684\uff0c\u6bd4\u5982\u8bf4\u6e38\u620f\u3001\u6570\u5b66\u5efa\u6a21\u3001\u4eba\u5de5\u667a\u80fd\u7b49\u7b49\u3002</p> <ul> <li> <p>\u6e38\u620f\u4e2d\u4eba\u7269\u7684\u5404\u79cd\u7279\u5f81\uff0c\u76ae\u80a4\u3001\u53d1\u8272\u3001\u5fc3\u60c5\u3001\u5750\u6807\u7b49\u7b49\u5404\u79cd\u7ef4\u5ea6\u90fd\u9700\u8981\u5b9e\u65f6\u5730\u5728\u7a0b\u5e8f\u4e2d\u8fdb\u884c\u5efa\u6a21\u4f53\u73b0\uff0c\u5e76\u6295\u5c04\u5230\u5c4f\u5e55\u4e2d\u3002</p> </li> <li> <p>\u4eba\u5de5\u667a\u80fd\u9886\u57df\u5982\u6bcf\u4e2atoken\u6240\u4ee3\u8868\u7684\u7279\u5f81\u7684\u5404\u79cd\u542b\u4e49\u4e5f\u9700\u8981\u901a\u8fc7\u5411\u91cf\u8fdb\u884c\u8868\u793a\u3002</p> </li> </ul> <p>\u800c\u7ebf\u6027\u4ee3\u6570\u7684\u5404\u79cd\u53d8\u5316\u7b49\u4e3a\u8fd9\u4e9b\u573a\u666f\u8868\u793a\u8fdb\u884c\u4e86\u62bd\u8c61\u6253\u5305\uff0c\u80fd\u591f\u66f4\u597d\u5730\u5c06\u8fd9\u4e9b\u4e8b\u7269\u62bd\u8c61\u6210\u53ef\u4ee5\u7531\u8ba1\u7b97\u673a\u8868\u793a\u7684\u6570\u5b66\u7279\u5f81\u3002</p> <p>\u6240\u4ee5\u6211\u5bf9\u7ebf\u6027\u4ee3\u6570\u7684\u7406\u89e3\uff0c\u5c31\u662f\u5b83\u662f\u4e00\u79cd\u5efa\u6a21\u7684\u5de5\u5177\uff0c\u540c\u65f6\u5bf9\u62bd\u8c61\u5efa\u6a21\u51fa\u6765\u7684\u6570\u5b66\u8868\u793a\uff0c\u63d0\u4f9b\u4e86\u4e00\u5957\u5b8c\u6574\u7684\u7ebf\u6027\u53d8\u5316\u89c4\u5219\u3002\u6bd4\u5982\u7f29\u653e\uff0c\u76f8\u52a0\u7b49\uff0c\u80fd\u591f\u7531\u8ba1\u7b97\u673a\u8fdb\u884c\u66f4\u597d\u5730\u6570\u636e\u5904\u7406\uff0c\u5b8c\u6210\u5404\u9879\u5de5\u4f5c\u3002</p> <p>\u63a8\u8350B\u7ad9\u6559\u7a0b\uff08\u7b80\u77ed\uff09\uff1a3Blue1Brown\u7ebf\u6027\u4ee3\u6570\u7684\u672c\u8d28</p>"},{"location":"ai/math/linear_algebra/eigenvalue.html","title":"eigenvalue","text":"<p>\ud83d\udea7 \u6b63\u5728\u66f4\u65b0\u4e2d...</p>"},{"location":"ai/math/linear_algebra/eigenvalue.html#_1","title":"\ud83d\udccc \u8ba1\u5212\u5185\u5bb9","text":"<ul> <li>\uff08\u5f85\u8865\u5145\uff09</li> </ul>"},{"location":"ai/math/linear_algebra/matrix.html","title":"\u77e9\u9635\u4e0e\u7ebf\u6027\u53d8\u6362","text":"<p>\u7ebf\u6027\u53d8\u6362\u53ef\u4ee5\u7406\u89e3\u4e3a\u5c31\u662f\u5bf9\u5411\u91cf\u7684\u4e00\u79cd\u53d8\u5316\uff0c\u4e00\u4e2a\u5411\u91cf\u7ecf\u8fc7\u67d0\u79cd\u51fd\u6570\uff0c\u53d8\u6210\u53e6\u4e00\u4e2a\u5411\u91cf\u7684\u8fd9\u4e48\u4e00\u4e2a\u5173\u7cfb\u3002</p> <p>\u5982\u8f93\u5165\u5411\u91cfX[1,1,1]\u8f93\u51fa\u5411\u91cfy[3,3,3]\u8fd9\u4e48\u4e00\u4e2a\u610f\u601d\u3002</p> <p>\u800c\u77e9\u9635\u5176\u5b9e\u76f8\u5f53\u4e8e\u8fd9\u5176\u4e2d\u53d8\u6362\u7684\u4e00\u4e2a\u5a92\u4ecb\uff0c\u5145\u5f53\u7740\u600e\u4e48\u53d8\u6362\u7684\u8fd9\u4e48\u4e00\u4e2a\u610f\u601d\u3002</p>"},{"location":"ai/math/linear_algebra/matrix.html#_2","title":"\u77e9\u9635","text":"<p>\u6211\u4eec\u77e5\u9053\u5411\u91cf\u63cf\u8ff0\u7684\u662f\u4e00\u79cd\u6a21\u578b\uff0c\u800c\u57fa\u5411\u91cf\u4ee3\u8868\u7684\u662f\u53ef\u4ee5\u63cf\u7ed8\u8fd9\u4e9b\u5411\u91cf\u7684\u5728\u8fd9\u4e2a\u7a7a\u95f4\u7684\u4e00\u4e2a\u57fa\u672c\u5355\u4f4d\uff0c\u4efb\u610f\u7684\u5411\u91cf\u90fd\u662f\u53ef\u4ee5\u901a\u8fc7\u57fa\u5411\u91cf\u901a\u8fc7\u7ebf\u6027\u7ec4\u5408\u8fdb\u884c\u8868\u793a\u7684\u3002</p> <p>\u800c\u8fd9\u4e2a\u7a7a\u95f4\uff0c\u4e00\u4e2a\u5411\u91cfV\uff0c\u901a\u8fc7\u67d0\u79cd\u53d8\u6362\u53d8\u6210\u4e86\u53e6\u4e00\u4e2a\u5411\u91cfV2\uff0c\u5176\u5b9e\u5bf9\u4e8eV\u548cV2\u6765\u8bf4\uff0c\u4ed6\u4eec\u53d8\u6362\u524d\u548c\u53d8\u6362\u540e\u548c\u539f\u6765\u57fa\u5411\u91cf\u7684\u7ebf\u6027\u7ec4\u5408\u7684\u5173\u7cfb\u90fd\u662f\u4fdd\u6301\u4e00\u81f4\u7684\u3002</p> <p>\u53ef\u4ee5\u7406\u89e3\u4e3a\uff1a</p> <pre><code>V = a * i + b * j\n</code></pre> <p>\u90a3\u4e48\u53d8\u6362\u540e</p> <pre><code>v2 = a * i (\u53d8) + b * j (\u53d8)\n</code></pre> <p>\u4ed6\u4eec\u8fd8\u662f\u57fa\u4e8e\u57fa\u5411\u91cfi\u4e58a\u52a0\u4e0a\u57fa\u5411\u91cfj\u4e58b\u76f8\u52a0\u7684\u8fd9\u4e48\u4e00\u4e2a\u7ed3\u679c\uff0c\u7ef4\u5ea6\u53d8\u7684\u53ea\u6709\u57fa\u5411\u91cf\u3002</p> <p>\u6240\u4ee5\u4efb\u610f\u5411\u91cf\u901a\u8fc7\u67d0\u79cd\u53d8\u6362\u53d8\u6210\u67d0\u4e2a\u53d8\u91cf\uff0c\u53ef\u4ee5\u770b\u6210\u5728\u8fd9\u4e2a\u7a7a\u95f4\u91cc\uff0c\u4ed6\u7684\u57fa\u5411\u91cf\u8ddf\u7740\u8fd9\u4e2a\u7a7a\u95f4\u4e00\u8d77\u53d8\u6362\u4e86\uff0c\u8fde\u5e26\u7740\u81ea\u5df1\u4e5f\u53d8\u6362\u4e86\u3002</p> <p>\u800c\u8fd9\u79cd\u53d8\u6362\u7684\u516c\u5f0f\uff0c\u5176\u5b9e\u5c31\u662f \u5411\u91cf\u548c\u77e9\u9635\u76f8\u4e58\u3002</p>"},{"location":"ai/math/linear_algebra/vector.html","title":"\u5411\u91cf","text":"<p>\u5411\u91cf\u53ef\u4ee5\u7406\u89e3\u4e3a\u5bf9\u4e00\u4e2a\u4e8b\u7269\u7684\u5404\u4e2a\u7279\u5f81\u7684\u4e00\u4e2a\u8868\u793a\u3002\u5411\u91cf\u7684\u6bcf\u4e00\u4e2a\u5206\u91cf\u4ee3\u8868\u4e00\u4e2a\u7279\u5f81\uff0c\u800c\u5bf9\u5411\u91cf\u7684\u8868\u793a\u5e94\u8be5\u770b\u6210\u4e00\u4e2a\u6574\u4f53\uff0c\u5982\u4e8c\u7ef4\u5e73\u9762\u7684\u5411\u91cf\u6240\u8868\u793a\u7684\u542b\u4e49\u5c31\u662f\u4e00\u4e2a\u7bad\u5934\u3002</p>"},{"location":"ai/math/linear_algebra/vector.html#_2","title":"\u4e8c\u7ef4\u5750\u6807\u8868\u793a","text":"<p>\u5982\u5750\u6807\u8f74\u4e8c\u7ef4\u5411\u91cf[1,2]\uff1a\u7b2c\u4e00\u4e2a\u7279\u5f81\u4ee3\u8868\u7684\u662f\u5411\u53f3\uff0c\u7b2c\u4e8c\u4e2a\u7279\u5f81\u4ee3\u8868\u7684\u662f\u5411\u4e0a\u3002</p> <p>\u90a3\u6574\u4f53\u6240\u4ee3\u8868\u7684\u542b\u4e49\u5c31\u662f\u4e00\u4e2a\u7bad\u5934\uff0c\u5b83\u5411\u5de6\u8d70\u4e86\u4e00\u6b65\uff0c\u53c8\u5411\u4e0a\u8d70\u4e86\u4e24\u6b65\u3002</p>"},{"location":"ai/math/linear_algebra/vector.html#_3","title":"\u73b0\u5b9e\u8868\u793a","text":"<ul> <li>\u623f\u4ef7\uff1a\u5982\u623f\u5b50\u7684\u4ef7\u683c\u5206\u6790\uff0c\u53ef\u4ee5\u901a\u8fc7\u623f\u5b50\u7684\u9762\u79ef\u548c\u4ef7\u683c\u8fdb\u884c\u5efa\u6a21\uff0c\u623f\u5b50\u6709\u4e24\u4e2a\u7279\u5f81\uff0c\u7b2c\u4e00\u4e2a\u662f\u9762\u79ef\uff0c\u7b2c\u4e8c\u4e2a\u662f\u4ef7\u683c\uff0c\u90a3\u540c\u6837\u7684\u53ef\u4ee5\u901a\u8fc7\u4e8c\u7ef4\u5411\u91cf\u8fdb\u884c\u8868\u793a\uff0c\u5982\uff1a90\u5e73230\u4e07\uff0c120\u5e73300\u4e07\u7b49\u7b49</li> </ul> <pre><code>[90,230]\n[120,300]\n[60,180]\n</code></pre> <ul> <li>\u5927\u8bed\u8a00\u6a21\u578b\uff1aTransformer\u6700\u5e38\u89c1\u7684Token\uff0c\u6bd4\u5982\u4e00\u4e2a\u8bcd\uff0c\u53ef\u4ee5\u7531token\u6765\u8868\u793a\uff0c\u800ctoken\u5176\u5b9e\u5c31\u662f\u4e00\u4e2a\u5411\u91cf\uff0c\u8fd9\u4e2a\u5411\u91cf\u53ef\u4ee5\u4e8c\u7ef4\uff0c\u4e5f\u53ef\u4ee5\u5f88\u591a\u7ef4\uff0c\u5373\u4e00\u4e2a\u8bcd\u8bed\u4f60\u53ef\u4ee5\u7528\u4e24\u4e2a\u7279\u5f81\u8868\u793a\uff0c\u4e5f\u53ef\u4ee5\u7528\u591a\u4e2a\u7279\u5f81\u6765\u8fdb\u884c\u8868\u793a\uff0c\u800c\u66f4\u591a\u7ef4\u5ea6\u7684\u8868\u793a\u6240\u80fd\u4f53\u73b0\u7684\u8bcd\u7684\u542b\u4e49\u5c31\u4f1a\u66f4\u4e30\u5bcc\u9971\u6ee1\u3002</li> </ul> <pre><code>[0.4561,0.1231,0.4564,0.1456...]\n</code></pre> <ul> <li>\u8ba1\u7b97\u673a\u89c6\u89c9\uff1a\u5bf9\u4e8e\u4eba\u773c\u6240\u770b\u5230\u7684\u56fe\u7247\u548c\u89c6\u9891\uff0c\u662f\u4e94\u989c\u516d\u8272\u7684\uff0c\u4f46\u662f\u5bf9\u4e8e\u8ba1\u7b97\u673a\u662f\u4e0d\u660e\u767d\u989c\u8272\u7684\u542b\u4e49\uff0c\u5728\u5e95\u5c42\u53ea\u6709\u4e8c\u8fdb\u5236\u7684\u6570\u5b66\u8868\u793a\uff0c\u90a3\u4e48\u5bf9\u4e8e\u4e00\u5f20\u56fe\u7247\uff0c\u53ef\u4ee5\u901a\u8fc7\u5411\u91cf\u62bd\u8c61\u5730\u8fdb\u884c\u8868\u793a\uff0c\u800c\u6bcf\u4e00\u4e2a\u7ef4\u5ea6\u5c31\u4ee3\u8868\u6bcf\u4e00\u4e2a\u50cf\u7d20\u5757\uff0c\u6bcf\u4e00\u4e2a\u50cf\u7d20\u5757\u7684\u503c\u6240\u4ee3\u8868\u7684\u5c31\u662frgb\u6570\u503c\u3002</li> </ul>"},{"location":"ai/math/linear_algebra/vector.html#_4","title":"\u5411\u91cf\u7684\u52a0\u6cd5","text":"<p>\u5411\u91cf\u7684\u52a0\u6cd5\u53ef\u4ee5\u7406\u89e3\u4e3a\u6240\u62bd\u8c61\u51fa\u6765\u7684\u6a21\u578b\u76f8\u52a0\uff0c\u90a3\u4e48\u4e24\u4e2a\u6a21\u578b\u672c\u8eab\u5c31\u662f\u62bd\u8c61\u7684\uff0c\u518d\u76f8\u52a0\u5c31\u66f4\u62bd\u8c61\u4e86\uff0c\u6240\u4ee5\u901a\u8fc7\u6570\u5b66\u7684\u8868\u793a\u6765\u8bf4\uff0c\u5411\u91cf\u7684\u76f8\u52a0\u6240\u4ee3\u8868\u7684\u5c31\u662f\u5411\u91cf\u7684\u5404\u4e2a\u5206\u91cf\u76f8\u52a0\u3002</p> <p>\u90a3\u600e\u4e48\u53bb\u7406\u89e3\u4e24\u4e2a\u6a21\u578b\u7684\u76f8\u52a0\u5462\uff0c\u6700\u7b80\u5355\u7684\u8fd8\u662f\u4ee5\u4e8c\u7ef4\u5750\u6807\u7bad\u5934\u4e3a\u4f8b\u5b50\uff0c\u4e24\u4e2a\u7bad\u5934\u7684\u76f8\u52a0\uff0c\u5176\u5b9e\u5c31\u662f\u5c06\u7b2c\u4e8c\u4e2a\u7bad\u5934\u8fde\u7ed3\u5230\u7b2c\u4e00\u4e2a\u7bad\u5934\u4e4b\u4e0a\uff0c\u7531\u539f\u70b9\u753b\u4e00\u6761\u76f4\u7ebf\uff0c\u5982\u4e0b\u56fe\u6240\u793a\u3002</p> <p></p> <p>\u90a3\u5176\u5b9e\u8fd9\u79cd\u7bad\u5934\u7684\u76f8\u52a0\uff0c\u5c31\u662fV[1,2]\u548cW[3,-1]\u76f8\u52a0\uff0cV\u6240\u4ee3\u8868\u7684\u542b\u4e49\u5c31\u662f\u5411\u5de6\u4e00\u6b65\uff0c\u5411\u4e0a\u4e24\u6b65\uff0cW\u6240\u4ee3\u8868\u7684\u542b\u4e49\u662f\u5411\u5de6\u4e09\u6b65\uff0c\u5411\u4e0b\u4e00\u6b65\u3002\u6240\u4ee5\u6700\u7ec8\u5c31\u662f\u5411\u5de63+1\u4e3a\u56db\u6b65\uff0c\u5411\u4e0a2-1\u4e3a\u4e00\u6b65\uff0c\u6700\u7ec8\u7684\u5411\u91cf\u5c31\u662f[4,1]\u3002</p> <p>\u90a3\u5bf9\u4e8e\u73b0\u5b9e\u8ba1\u7b97\u673a\u8868\u793a\u7684\u6a21\u578b\uff0c\u53ef\u4ee5\u7406\u89e3\u4e3a\u76f8\u52a0\uff0c\u5c31\u662f\u5bf9\u5404\u4e2a\u5206\u91cf\u7279\u5f81\u7684\u76f8\u52a0\u7684\u7ed3\u679c\uff0c\u7ed3\u679c\u662f\u65b0\u7684\u4e00\u4e2a\u76f8\u52a0\u540e\u7684\u6a21\u578b\u3002</p>"},{"location":"ai/math/linear_algebra/vector.html#_5","title":"\u5411\u91cf\u7684\u4e58\u6cd5","text":"<p>\u5411\u91cf\u7684\u4e58\u6cd5\u6211\u89c9\u5f97\u6bd4\u52a0\u6cd5\u662f\u8981\u597d\u7406\u89e3\u7684\uff0c\u4e58\u6cd5\u5176\u5b9e\u5bf9\u4e8e\u5411\u91cf\u5176\u5b9e\u5c31\u662f\u4e00\u4e2a\u7f29\u653e\u7684\u6548\u679c\uff0c\u5bf9\u6240\u6709\u7684\u7279\u5f81\u8fdb\u884c\u4e00\u4e2a\u653e\u5927\u6216\u653e\u5c0f\u3002</p>"},{"location":"ai/math/linear_algebra/vector.html#_6","title":"\u57fa\u5411\u91cf","text":"<p>\u57fa\u5411\u91cf\u53ef\u4ee5\u7406\u89e3\u4e3a\u5c31\u662f\u4e00\u4e2a\u57fa\u7840\u7684\u5411\u91cf\uff0c\u57fa\u5411\u91cf\u672c\u8d28\u4e5f\u662f\u4e00\u4e2a\u5411\u91cf\uff0c\u7528\u6765\u5b9a\u4e49\u8fd9\u4e2a\u6a21\u578b\u548c\u7a7a\u95f4\u7684\u57fa\u672c\u5355\u4f4d\u3002</p> <p>\u5982\u4f55\u5b9a\u4e49\u57fa\u5411\u91cf\u5462\uff1f</p> <p>\u6211\u4eec\u53ef\u4ee5\u5148\u6311\u4efb\u610f\u4e24\u4e2a\u5411\u91cf\uff0c\u90a3\u4e48\u4efb\u610f\u4e24\u4e2a\u5411\u91cf\u53ef\u4ee5\u901a\u8fc7\u5404\u79cd\u7ebf\u6027\u7ec4\u5408\uff08v = ai + bj\uff09\u5c31\u662f\u4e24\u4e2a\u5411\u91cf\u4e58\u5404\u81ea\u7f29\u653e\u500d\u6570\u518d\u76f8\u52a0\uff0c\u6240\u7ec4\u6210\u7684\u4e00\u4e2a\u7a7a\u95f4\u548c\u96c6\u5408\uff0c\u7406\u8bba\u4e0a\u53ef\u4ee5\u6269\u5c55\u5230\u6574\u4e2a\u7a7a\u95f4\uff0c\u6211\u4eec\u79f0\u4e4b\u4e3a\u53eb\u5f20\u6210\u7a7a\u95f4\uff0c\u90a3\u4e48\u6709\u4e24\u79cd\u60c5\u51b5\uff1a</p> <ul> <li>\u5f20\u6210\u7a7a\u95f4\u8fd8\u662f\u4e00\u6761\u76f4\u7ebf</li> <li>\u5f20\u6210\u7a7a\u95f4\u53d8\u6210\u4e00\u4e2a\u9762\uff0c\u5bf9\u7ef4\u5ea6\u6709\u8d21\u732e</li> </ul> <p>\u6211\u4eec\u8bf4\u4efb\u610f\u4e24\u4e2a\u5411\u91cf\uff0c\u5bf9\u5f20\u6210\u7a7a\u95f4\u7ef4\u5ea6\u6709\u8d21\u732e\u7684\uff0c\u79f0\u4e4b\u4e3a\u7ebf\u6027\u65e0\u5173\u3002\u5bf9\u5f20\u6210\u7a7a\u95f4\u7ef4\u5ea6\u6ca1\u8d21\u732e\u7684\u53eb\u505a\u7ebf\u6027\u76f8\u5173\uff0c\u53ef\u4ee5\u7406\u89e3\u4e3a\u5c31\u662f\u7b2c\u4e8c\u4e2a\u5411\u91cf\u548c\u7b2c\u4e00\u4e2a\u5411\u91cf\u662f\u5904\u4e8e\u540c\u4e00\u4e2a\u7ef4\u5ea6\uff0c\u540c\u4e00\u4e2a\u76f4\u7ebf\uff0c\u6ca1\u6cd5\u8fdb\u884c\u6269\u5c55\uff0c\u6240\u4ee5\u53eb\u505a\u7ebf\u6027\u76f8\u5173\u3002</p> <p>\u90a3\u4e48\u6211\u4eec\u5b9a\u4e49\u57fa\u5411\u91cf\uff0c\u5c31\u662f\u5fc5\u987b\u662f\u4e24\u4e2a\u7ebf\u6027\u65e0\u5173\u7684\u5411\u91cf\u624d\u80fd\u53eb\u505a\u57fa\u5411\u91cf\u3002\u6269\u5c55\u5230\u4e09\u7ef4\u6216\u66f4\u9ad8\u7ef4\u5ea6\u4e5f\u662f\u540c\u7406\u7684\u3002</p>"},{"location":"ai/math/linear_algebra/vector.html#_7","title":"\u57fa\u5411\u91cf\u7684\u53d8\u6362","text":"<p>\u6211\u4eec\u559c\u6b22\u4e60\u60ef\u6027\u601d\u7ef4\uff0c\u6b63\u5e38\u7684\u5750\u6807\u8f74\u5176\u5b9e\u57fa\u5411\u91cf\u5c31\u662f[1,0]\u548c[0,1]\uff0c\u4f46\u662f\u901a\u8fc7\u5404\u79cd\u5404\u6837\u7684\u7ebf\u6027\u53d8\u6362\uff0c\u5176\u5b9e\u672c\u8d28\u5c31\u662f\u5bf9\u57fa\u5411\u91cf\u7684\u53d8\u6362\uff0c\u57fa\u5411\u91cf\u53ef\u4ee5\u53d8\u6362\u6210\u5404\u79cd\u5404\u6837\u7684\uff0c\u53ef\u4ee5\u662f\u659c\u7740\u7684\uff0c\u5012\u8f6c\u7684\uff0c\u7ffb\u8f6c\u7684\u7b49\u7b49\uff0c\u6240\u4ee3\u8868\u7684\u6570\u503c\u90fd\u662f\u4e0d\u4e00\u6837\u7684\u3002</p> <p>\u5982\u65cb\u8f6c90\u5ea6\uff0c\u5c31\u662f[0,1]\uff0c[-1,0]\u4e24\u4e2a\u57fa\u5411\u91cf\uff0c\u800c\u968f\u4e4b\u5728\u539f\u6765\u5750\u6807\u8f74\u4e0a\u7684v\u5411\u91cf\uff0c\u4e5f\u4f1a\u8ddf\u7740\u57fa\u5411\u91cf\u4e00\u540c\u53d8\u6362\uff0c\u8fd9\u5c31\u5f15\u51fa\u4e86\u77e9\u9635\u7684\u6982\u5ff5\u4e86\uff0c\u4e14\u542c\u4e0b\u56de\u5206\u89e3~</p>"},{"location":"ai/optimization/index.html","title":"optimization","text":"<p>\ud83d\udea7 \u6b63\u5728\u66f4\u65b0\u4e2d...</p>"},{"location":"ai/optimization/index.html#_1","title":"\ud83d\udccc \u8ba1\u5212\u5185\u5bb9","text":"<ul> <li>\uff08\u5f85\u8865\u5145\uff09</li> </ul>"},{"location":"ai/reinforcement_learning/index.html","title":"reinforcement_learning","text":"<p>\ud83d\udea7 \u6b63\u5728\u66f4\u65b0\u4e2d...</p>"},{"location":"ai/reinforcement_learning/index.html#_1","title":"\ud83d\udccc \u8ba1\u5212\u5185\u5bb9","text":"<ul> <li>\uff08\u5f85\u8865\u5145\uff09</li> </ul>"},{"location":"ai/training/index.html","title":"training","text":"<p>\ud83d\udea7 \u6b63\u5728\u66f4\u65b0\u4e2d...